# Local BME configuration
# Set MODELS_PATH to your models directory (Windows path or WSL /mnt/c/...)
MODELS_PATH=C:\Users\Michelle\Models

# GGUF model filename inside MODELS_PATH (default: Qwen3-4B-Q4_K_M.gguf)
SLM_MODEL=Qwen3-4B-Q4_K_M.gguf

# Set SLM_DISABLED=true to skip model loading (uses text fallback)
# SLM_DISABLED=false

# JWT secret - change this!
JWT_SECRET=change-this-to-a-long-random-string

# Optional admin seed (used by /api/db/init)
ADMIN_EMAIL=bookkeeper@local
ADMIN_PASSWORD=change-me-now

# For optional remote LibSQL/Turso (leave for pure local.db)
# TURSO_DATABASE_URL=
# TURSO_AUTH_TOKEN=